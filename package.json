{
  "name": "voicenexus-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-tenant AI calling and customer communication platform",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "predev": "pnpm --filter @voicenexus/contracts build",
    "dev": "turbo dev --parallel",
    "dev:web": "pnpm --filter @voicenexus/web dev",
    "dev:api": "pnpm --filter @voicenexus/api dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "test": "turbo test",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "clean": "turbo clean && node ./tools/clean.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "eslint": "^9.29.0",
    "globals": "^16.2.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1"
  }
}
