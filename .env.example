# VoiceNexus AI root environment reference.
# Each app owns its runtime variables. Copy these files before local development:
#
#   apps/api/.env.example -> apps/api/.env
#   apps/web/.env.example -> apps/web/.env.local
#   services/realtime-gateway/.env.example -> services/realtime-gateway/.env
#   services/ai-brain/.env.example -> services/ai-brain/.env
#   services/automation-worker/.env.example -> services/automation-worker/.env
#
# MongoDB Atlas is the Phase 1 database. The backend service layer uses repository
# interfaces so the persistence implementation can be migrated later without
# rewriting application services.
#
# Phase 5.1 realtime gateway foundation also requires Redis for active realtime state:
#   REDIS_URL=redis://localhost:6379
#   REALTIME_GATEWAY_PORT=4001
#   MEDIA_STREAM_SECRET=replace-with-at-least-32-random-characters
#   DEEPGRAM_API_KEY=replace-with-your-deepgram-api-key
#   TTS_PROVIDER=openai
#   OPENAI_API_KEY=replace-with-your-openai-api-key
#   OPENAI_TTS_MODEL=gpt-4o-mini-tts
#   ELEVENLABS_API_KEY=replace-with-your-elevenlabs-api-key
#   ELEVENLABS_VOICE_ID=replace-with-elevenlabs-voice-id
#   CARTESIA_API_KEY=replace-with-your-cartesia-api-key
#   CARTESIA_VOICE_ID=replace-with-cartesia-voice-id
#
# Phase 5.3/5.4 AI Brain:
#   AI_BRAIN_PORT=4002
#   OPENAI_API_KEY=replace-with-your-openai-api-key
#   OPENAI_MODEL=gpt-4o
#
# Phase 5.5.1 automation worker:
#   WORKER_POLL_INTERVAL_MS=60000
#   WORKER_BATCH_SIZE=100
#   WORKER_MAX_RETRIES=5
OPENAI_API_KEY=replace-with-your-openai-api-key
OPENAI_MODEL=gpt-4o
MONGODB_URI=mongodb+srv://username:password@cluster.example.mongodb.net/voicenexus?retryWrites=true&w=majority
TWILIO_ACCOUNT_SID=replace-with-your-twilio-account-sid
TWILIO_AUTH_TOKEN=replace-with-your-twilio-auth-token
TWILIO_PHONE_NUMBER=+15555550100
GROQ_API_KEY=replace-with-your-groq-api-key
GEMINI_API_KEY=replace-with-your-gemini-api-key
