NODE_ENV=development
REALTIME_GATEWAY_PORT=4001
FRONTEND_URL=http://localhost:3000
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/voicenexus
MONGODB_DB_NAME=voicenexus
REDIS_URL=redis://localhost:6379
MEDIA_STREAM_SECRET=replace-with-at-least-32-random-characters
# Legacy alias MEDIA_STREAM_TOKEN_SECRET is accepted by both AI Brain and Realtime Gateway; use MEDIA_STREAM_SECRET when possible.
DEEPGRAM_API_KEY=replace-with-your-deepgram-api-key
OPENAI_API_KEY=replace-with-your-openai-api-key
OPENAI_TTS_MODEL=gpt-4o-mini-tts
ELEVENLABS_API_KEY=replace-with-your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=replace-with-elevenlabs-voice-id
CARTESIA_API_KEY=replace-with-your-cartesia-api-key
CARTESIA_VOICE_ID=replace-with-cartesia-voice-id
TTS_PROVIDER=openai
JWT_ACCESS_SECRET=replace-with-the-same-32-character-access-secret-used-by-the-api
JWT_ISSUER=voicenexus-api
JWT_AUDIENCE=voicenexus-web
