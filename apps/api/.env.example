NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb+srv://username:password@cluster.example.mongodb.net/voicenexus?retryWrites=true&w=majority
MONGODB_DB_NAME=voicenexus
JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters-access
JWT_REFRESH_SECRET=replace-with-at-least-32-random-characters-refresh
JWT_ISSUER=voicenexus-api
JWT_AUDIENCE=voicenexus-web
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800
BCRYPT_ROUNDS=12
FRONTEND_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:4000
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
COOKIE_SECURE=false
TRUST_PROXY=1
